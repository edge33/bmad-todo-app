{
  "name": "todoapp",
  "version": "0.0.1",
  "description": "A modern todo application with monorepo structure",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:frontend": "pnpm --filter @todoapp/frontend run dev",
    "dev:backend": "pnpm --filter @todoapp/backend run dev",
    "start:backend": "pnpm --filter @todoapp/backend run start",
    "build": "pnpm --filter './packages/**' run build && pnpm --filter './apps/**' run build",
    "test:unit": "pnpm --filter @todoapp/backend run test:unit",
    "test:feature": "pnpm --filter @todoapp/backend run test:feature",
    "test:e2e": "pnpm --filter @todoapp/frontend run test:e2e",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "format:check": "biome format --check .",
    "type-check": "pnpm -r run type-check",
    "db:migrate": "pnpm --filter @todoapp/backend run db:migrate",
    "commit": "cz",
    "clean": "pnpm -r exec rm -rf dist node_modules && rm -rf pnpm-lock.yaml",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^24.0.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "biome check --write",
    "*.json": "biome check --write",
    "*.md": "biome check --write"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
