{
  "name": "@todoapp/backend",
  "version": "0.0.1",
  "description": "Fastify backend API server",
  "type": "module",
  "scripts": {
    "dev": "node src/index.ts",
    "build": "tsc --noEmit && tsc",
    "start": "node dist/index.js",
    "check:types": "tsc --noEmit",
    "lint": "eslint src --ext ts --report-unused-disable-directives",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^4.25.2",
    "@todoapp/shared-types": "workspace:*",
    "@todoapp/shared-utils": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6"
  }
}
