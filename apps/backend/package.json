{
  "name": "@todoapp/backend",
  "version": "0.0.1",
  "description": "Fastify backend API server",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --watch src/index.ts",
    "build": "echo 'no build required for backend'",
    "start": "node src/index.ts",
    "type-check": "tsc --noEmit",
    "test:unit": "NODE_ENV=test node --test --experimental-test-coverage --experimental-test-module-mocks",
    "test:unit:ci": "NODE_ENV=test c8 --reporter=lcov --reporter=text --reports-dir=coverage node --test --experimental-test-module-mocks",
    "test:feature": "cd bruno && bru run tasks --env local --output results.xml --format junit",
    "test:feature:ci": "cd bruno && bru run tasks --env ci --output results.xml --format junit",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cors": "^11.2.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@todoapp/shared-types": "workspace:*",
    "@todoapp/shared-utils": "workspace:*",
    "close-with-grace": "^2.5.0",
    "fastify": "^5.8.4"
  },
  "devDependencies": {
    "@usebruno/cli": "^3.2.2",
    "c8": "^11.0.0",
    "prisma": "^7.7.0"
  }
}
