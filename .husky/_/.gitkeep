#!/bin/sh
if [ "$1" = "install" ]; then
  DIR="$(cd "$(dirname "$0")" && pwd)"
  HOOK_DIR="$(dirname "$DIR")"
  HUSKY_SH="$HOOK_DIR/_/husky.sh"
  mkdir -p "$(dirname "$HUSKY_SH")"
  cat > "$HUSKY_SH" << 'EOF'
#!/bin/sh
# This is a Husky helper script to support hook operations.
# Generated by setup process.
EOF
  chmod +x "$HUSKY_SH"
fi
