# Environment Configuration for todoapp
# Copy this file to .env and customize values for your local environment
# Do NOT commit .env to version control (see .gitignore)

# PostgreSQL Database (Development)
# Used by docker-compose.yml and local development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/todoapp_dev
POSTGRES_PASSWORD=postgres
POSTGRES_INITDB_ARGS=

# Testing Database (used by CI/CD and local integration tests)
# Separate from development database to prevent data loss during testing
# DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/todoapp_test

# Backend Service
BACKEND_PORT=3000
BACKEND_URL=http://localhost:3000
# NODE_ENV: 'development' for local dev, 'test' for CI/CD, 'production' for production
NODE_ENV=development

# Frontend Service
FRONTEND_PORT=5173
# VITE_API_URL: The backend URL that frontend code calls (can differ from BACKEND_URL)
VITE_API_URL=http://localhost:3000

# CI/CD Environment (GitHub Actions)
# These are automatically set in .github/workflows/test.yml
# NODE_ENV=test
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/todoapp_test
